<Window x:Class="PhoneBookWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Телефонная книга" Height="450" Width="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Ввод данных -->
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Имя:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Width="200"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Телефон:" Margin="16,0,0,0" VerticalAlignment="Center"/>
            <TextBox Width="200" Margin="8,0,0,0"
                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
            <Button Content="Добавить"
                    Command="{Binding AddCommand}" Width="120"/>
            <Button Content="Удалить" Margin="8,0,0,0"
                    Command="{Binding DeleteCommand}"
                    CommandParameter="{Binding SelectedContact}"
                    Width="120"/>
        </StackPanel>

        <!-- Список -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Contacts}"
                  SelectedItem="{Binding SelectedContact, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
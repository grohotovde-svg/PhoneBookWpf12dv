<Window x:Class="PhoneBookWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Телефонная книга" Height="550" Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Блок добавления контакта -->
        <GroupBox Grid.Row="0" Header="Добавить контакт" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Имя:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" 
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5,0" VerticalAlignment="Center"/>

                <Label Grid.Column="2" Content="Телефон:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="3" 
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5,0" VerticalAlignment="Center"/>

                <Button Grid.Column="4" Content="Добавить"
                        Command="{Binding AddCommand}"
                        Padding="10,3"/>
            </Grid>
        </GroupBox>

        <!-- Список контактов -->
        <GroupBox Grid.Row="1" Header="Список контактов">
            <ListView ItemsSource="{Binding Contacts}"
                      SelectedItem="{Binding SelectedContact}"
                      x:Name="ContactsList">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" 
                                        DisplayMemberBinding="{Binding Id}" 
                                        Width="50"/>
                        <GridViewColumn Header="Имя" 
                                        DisplayMemberBinding="{Binding Name}" 
                                        Width="250"/>
                        <GridViewColumn Header="Телефон" 
                                        DisplayMemberBinding="{Binding Phone}" 
                                        Width="200"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Редактировать"
                    Command="{Binding EditCommand}"
                    CommandParameter="{Binding SelectedContact}"
                    Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="Удалить"
                    Command="{Binding DeleteCommand}"
                    CommandParameter="{Binding SelectedContact}"
                    Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>